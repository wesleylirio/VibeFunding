# Application
DEMO_MODE=true
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0
DATABASE_URL=file:./data/app.db

# Gemma: auto = try live backend when keys exist, else offline fallback
# mock = always offline (product UI still works)
GEMMA_PROVIDER=auto

# ─── Fireworks AI + AMD (PRIMARY / hackathon path) ───
# Server-side only. Never commit real keys.
# Gemma 4 31B IT on Fireworks = ON-DEMAND dedicated deployment (AMD-backed).
# Create deployment → copy accounts/<account>/deployments/<id>
# Start deploy for recording/live pitch; delete when idle (bills per GPU hour).
# FIREWORKS_API_KEY=
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# FIREWORKS_MODEL=accounts/YOUR_ACCOUNT_ID/deployments/YOUR_DEPLOYMENT_ID
# GEMMA_MODEL=accounts/YOUR_ACCOUNT_ID/deployments/YOUR_DEPLOYMENT_ID

# ─── OpenRouter free Gemma (FALLBACK only — always-on public demo) ───
# NOT the designed primary path. Use when Fireworks on-demand credits/deploy
# are gone so the hosted judge URL still has live Gemma. Same app surface.
# Default free model: google/gemma-4-31b-it:free
# Priority: FIREWORKS_API_KEY first, then OPENROUTER_API_KEY.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_SITE_URL=https://vibefunding.app
OPENROUTER_SITE_NAME=VibeFunding

# GEMMA_TIMEOUT_MS=60000
# GEMMA_MAX_OUTPUT_TOKENS=2048
# GEMMA_CACHE_TTL_MS=300000

# Optional alternate OpenAI-compatible endpoint
# GEMMA_BASE_URL=
# GEMMA_API_KEY=
