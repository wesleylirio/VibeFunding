# Application
DEMO_MODE=true
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0
DATABASE_URL=file:./data/app.db

# Gemma provider: auto | amd | mock | cache
# auto = attempt AMD when configured, else deterministic fallback
GEMMA_PROVIDER=auto

# AMD Developer Cloud — OpenAI-compatible Gemma endpoint (server-side only)
# Never commit real values. Never expose to the browser.
GEMMA_BASE_URL=
GEMMA_API_KEY=
GEMMA_MODEL=google/gemma-4-12B-it
GEMMA_TIMEOUT_MS=30000
GEMMA_MAX_OUTPUT_TOKENS=2048
GEMMA_CACHE_TTL_MS=900000

# Optional Fireworks (future)
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=
FIREWORKS_MODEL=
