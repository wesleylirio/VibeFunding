# Copy to a secure local file outside git. Never commit real tokens.

# Hugging Face (for model download on the AMD VM)
HF_TOKEN=

# Model
HF_MODEL=google/gemma-4-12B-it

# Serving
HOST=0.0.0.0
PORT=8000
# Optional API key the OpenAI-compatible server should require
INFERENCE_API_KEY=

# VibeFunding application (set on the app host / docker compose)
GEMMA_PROVIDER=auto
GEMMA_BASE_URL=http://YOUR_AMD_HOST:8000/v1
GEMMA_API_KEY=${INFERENCE_API_KEY}
GEMMA_MODEL=google/gemma-4-12B-it
GEMMA_TIMEOUT_MS=30000
GEMMA_MAX_OUTPUT_TOKENS=2048
